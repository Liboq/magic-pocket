{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Magic Pocket",
  "version": "0.1.0",
  "identifier": "com.magicpocket.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Magic Pocket",
        "width": 540,
        "height": 500,
        "minWidth": 420,
        "minHeight": 420,
        "transparent": true,
        "decorations": false,
        "shadow": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"]
  }
}
